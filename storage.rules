rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ===== Biblioteca COMPARTIDA de normas =====
    // La leen todos los usuarios autenticados; solo el administrador puede subir/borrar.
    match /fuf_biblioteca_shared/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'marcoaraya1973@gmail.com'
                   && (request.resource == null
                       || (request.resource.size < 15 * 1024 * 1024
                           && request.resource.contentType == 'application/pdf'));
    }

    // ===== Carpeta privada por usuario (reservada para uso futuro) =====
    match /fuf_biblioteca/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                   && (request.resource == null
                       || (request.resource.size < 15 * 1024 * 1024
                           && request.resource.contentType == 'application/pdf'));
    }
  }
}
